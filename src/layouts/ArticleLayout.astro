---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props;
const { title, description, pubDate, updatedDate, type, keywords, faq } = entry.data;

const typeLabels: Record<string, string> = {
  comparatif: 'Comparatif',
  complet: 'Guide complet',
  thematique: 'Astuce & idée',
};

const dateFmt = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  keywords: keywords.join(', '),
  mainEntityOfPage: canonicalURL,
  author: { '@type': 'Organization', name: 'GuideAirfryer' },
  publisher: { '@type': 'Organization', name: 'GuideAirfryer' },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'Articles', item: new URL('/articles/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalURL },
  ],
};

const jsonLd: Record<string, unknown>[] = [articleJsonLd, breadcrumbJsonLd];

if (faq && faq.length > 0) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  });
}
---

<BaseLayout title={`${title} | GuideAirfryer`} description={description} type="article" jsonLd={jsonLd}>
  <nav class="breadcrumbs">
    <a href="/">Accueil</a> / <a href="/articles/">Articles</a> / {title}
  </nav>
  <article class="post">
    <span class="tag">{typeLabels[type]}</span>
    <h1>{title}</h1>
    <p class="meta">
      Publié le {dateFmt.format(pubDate)}
      {updatedDate && ` · Mis à jour le ${dateFmt.format(updatedDate)}`}
    </p>
    <div class="disclosure">
      Cet article contient des liens d'affiliation Amazon. En tant que Partenaire Amazon,
      GuideAirfryer réalise un bénéfice sur les achats remplissant les conditions requises, sans
      surcoût pour vous.
    </div>
    <div class="content">
      <slot />
    </div>

    {faq && faq.length > 0 && (
      <section class="faq">
        <h2>Questions fréquentes</h2>
        {faq.map((item) => (
          <div class="faq-item">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </div>
        ))}
      </section>
    )}
  </article>
</BaseLayout>
