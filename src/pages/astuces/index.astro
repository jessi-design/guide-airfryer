---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => data.type === 'thematique')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Astuces & recettes airfryer | GuideAirfryer"
  description="Idées de recettes, astuces pratiques et conseils thématiques autour de la friteuse sans huile."
  wide
>
  <section class="hero">
    <h1>Astuces & recettes</h1>
    <p>Idées de recettes, astuces d'entretien et conseils pratiques au quotidien.</p>
  </section>
  <div class="article-grid">
    {articles.map((entry) => <ArticleCard entry={entry} />)}
  </div>
</BaseLayout>
