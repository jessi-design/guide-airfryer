---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => data.type === 'complet')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Guides complets airfryer | GuideAirfryer"
  description="Guides complets pour bien utiliser sa friteuse sans huile : réglages, entretien, recettes et conseils d'achat détaillés."
  wide
>
  <section class="hero">
    <h1>Guides complets</h1>
    <p>Des guides détaillés pour maîtriser votre airfryer du choix à l'utilisation quotidienne.</p>
  </section>
  <div class="article-grid">
    {articles.map((entry) => <ArticleCard entry={entry} />)}
  </div>
</BaseLayout>
