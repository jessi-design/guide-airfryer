---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => Boolean(data.pinImage)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Kit Pinterest | GuideAirfryer"
  description="Page interne : images et textes prêts à publier sur Pinterest."
  noindex
>
  <section class="hero">
    <h1>Kit Pinterest</h1>
    <p>Une épingle par article, générée automatiquement. Télécharge l'image, copie le titre et la description, colle sur Pinterest.</p>
  </section>

  <div class="pin-list">
    {articles.map((entry) => (
      <div class="pin-card">
        <img src={entry.data.pinImage} alt={`Épingle Pinterest pour ${entry.data.title}`} loading="lazy" />
        <div class="pin-card-body">
          <a class="pin-download" href={entry.data.pinImage} download>Télécharger l'image</a>

          <label>Titre de l'épingle</label>
          <div class="copy-row">
            <input type="text" readonly value={entry.data.pinTitle} />
            <button type="button" class="copy-btn" data-copy-target="prev">Copier</button>
          </div>

          <label>Description de l'épingle</label>
          <div class="copy-row">
            <textarea readonly rows="4">{entry.data.pinDescription}</textarea>
            <button type="button" class="copy-btn" data-copy-target="prev">Copier</button>
          </div>

          <a class="pin-article-link" href={`/articles/${entry.data.slug}/`}>Voir l'article →</a>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const field = btn.previousElementSibling as HTMLInputElement | HTMLTextAreaElement | null;
      if (!field) return;
      await navigator.clipboard.writeText(field.value);
      const original = btn.textContent;
      btn.textContent = 'Copié !';
      setTimeout(() => { btn.textContent = original; }, 1500);
    });
  });
</script>

<style>
  .pin-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0 4rem;
  }
  .pin-card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-card-bg);
  }
  .pin-card img {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: 0;
  }
  .pin-card-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pin-download {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    text-decoration: none;
    text-align: center;
    padding: 0.5rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .pin-card-body label {
    font-size: 0.75rem;
    color: var(--color-muted);
    font-weight: 600;
    margin-top: 0.25rem;
  }
  .copy-row {
    display: flex;
    gap: 0.4rem;
    align-items: flex-start;
  }
  .copy-row input,
  .copy-row textarea {
    flex: 1;
    font-family: inherit;
    font-size: 0.82rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.4rem 0.5rem;
    resize: vertical;
  }
  .copy-btn {
    border: 1px solid var(--color-border);
    background: #fff;
    border-radius: 6px;
    padding: 0.4rem 0.6rem;
    font-size: 0.78rem;
    cursor: pointer;
    white-space: nowrap;
  }
  .copy-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .pin-article-link {
    font-size: 0.82rem;
    margin-top: 0.25rem;
  }
</style>
